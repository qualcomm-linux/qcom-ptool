# Takes rawprogram*.xml and contents.xml files as arguments, collects the
# filenames referenced, and checks if any gpt_* or zeros_* file is missing and
# if the filenames are known

set -eu

errors=no

for xml in "$@"; do
    dir="$(dirname "${xml}")"
    rawprogram_filenames="$(
        sed -En 's:.*filename="([^"]+)".*:\1:p' "${xml}"
    )"
    # for contents.xml, extract file_path/file_name pairs as relative paths
    contents_filenames="$(
        python3 -c "
import xml.etree.ElementTree as ET, sys
tree = ET.parse(sys.argv[1])
for el in tree.iter():
    fn = el.find('file_name')
    fp = el.find('file_path')
    if fn is not None and fn.text:
        # construct relative path by combining file_path and file_name, but only
        # if file_path is non-empty and not '.'
        path = fp.text.rstrip('/') if fp is not None and fp.text and fp.text != '.' else ''
        print(path + '/' + fn.text if path else fn.text)
" "${xml}" 2>/dev/null
    )"
    for file in $(
        echo ${rawprogram_filenames} ${contents_filenames} | sort -u
        ); do
        # for matching known filenames, use the basename (strip subdir from
        # contents.xml file_path); for checking file existence, use the
        # full relative path
        basename="${file##*/}"
        case "${basename}" in
          # expected files that should be generated by ptool: test if present
          gpt_*|zeros_*|patch*.xml|rawprogram*.xml)
            # except we don't generate SAIL programming files at the moment, so
            # don't test if these are present
            if [ "${file%/*}" = "./sail_nor" ]; then
                continue
            fi
            if ! [ -r "${dir}/${file}" ]; then
                errors=yes
                echo "Missing ${file} referenced in ${xml}" >&2
            fi
          ;;
          # known files that will be provided by the OS or boot binaries
          DISK) ;;
          XblRamdump.elf) ;;
          XblRamdump.xz) ;;
          abl.elf) ;;
          abl2esp-v7.elf) ;;
          adsp_dtbs.elf) ;;
          adsp_lite.lzma) ;;
          aop.mbn) ;;
          aop_devcfg.mbn) ;;
          boot.img) ;;
          bootfw1.bin) ;;
          bootfw2.bin) ;;
          cdt.bin) ;;
          cmnlib.mbn) ;;
          cmnlib64.mbn) ;;
          cpucp.elf) ;;
          cpucp_dtbs.elf) ;;
          dcd.mbn) ;;
          devcfg.mbn) ;;
          devcfg_iot.mbn) ;;
          devcfg_rfcomm.mbn) ;;
          devcfg_windows_hyp.mbn) ;;
          dtb.bin) ;;
          efi.bin) ;;
          emmc_appsboot.mbn) ;;
          featenabler.mbn) ;;
          fs_image_linux.tar.gz.mbn.img) ;;
          hyp.mbn) ;;
          hypvm.mbn) ;;
          hyp_ac_config.mbn) ;;
          imagefv.elf) ;;
          keymaster.mbn) ;;
          keymaster64.mbn) ;;
          keymint.mbn) ;;
          km4.mbn) ;;
          logfs_ufs_8mb.bin) ;;
          multi_image.mbn) ;;
          multi_image_qti.mbn) ;;
          pdp.elf) ;;
          pdp_cdb.elf) ;;
          pmic.elf) ;;
          prog_firehose_ddr.elf) ;;
          prog_firehose_lite.elf) ;;
          qsahara_device_programmer.xml) ;;
          qupv3fw.elf) ;;
          rootfs.img) ;;
          rpm.mbn) ;;
          sailhyp.elf) ;;
          sailsw1.elf) ;;
          sbc_1.0_8016.bin) ;;
          sbc_1.0_8096.bin) ;;
          sbl1.mbn) ;;
          sdi.mbn) ;;
          sec.dat) ;;
          secs2d.mbn) ;;
          sed.dat) ;;
          sequencer_ram.elf) ;;
          shrm.elf) ;;
          signed_firmware_soc_view.elf) ;;
          soccp.bin) ;;
          storsec.mbn) ;;
          tme_config.elf) ;;
          tools.fv) ;;
          tz.mbn) ;;
          tzapps.bin) ;;
          tz_ac_config.mbn) ;;
          tz_qti_config.mbn) ;;
          uefi.elf) ;;
          uefi_dtbs.elf) ;;
          uefi_dtbs.xz) ;;
          uefi_sec.mbn) ;;
          userdata.img) ;;
          xbl.elf) ;;
          xbl_ac_config.mbn) ;;
          xbl_config.elf) ;;
          xbl_feature_config.elf) ;;
          xbl_s.melf) ;;
          xbl_s_devprg_ns.melf) ;;
          xbl_sc.elf) ;;
          *)
            echo "Unknown ${file} referenced in ${xml}" >&2
            errors=1
          ;;
        esac
    done
done

if [ "${errors}" != no ]; then
    exit 1
fi
exit 0

