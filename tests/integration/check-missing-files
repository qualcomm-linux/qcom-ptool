          signed_firmware_soc_view.elf) ;;
          soccp.bin) ;;
          soccp.mbn) ;;
          storsec.mbn) ;;
          tme_config.elf) ;;
          tools.fv) ;;
          tz.mbn) ;;
          tzapps.bin) ;;
          tz_ac_config.mbn) ;;
          tz_qti_config.mbn) ;;
          uefi.elf) ;;
          uefi_dtbs.elf) ;;
          uefi_dtbs.xz) ;;
          uefi_sec.mbn) ;;
          userdata.img) ;;
          xbl.elf) ;;
          xbl_ac_config.mbn) ;;
          xbl_config.elf) ;;
          xbl_config_devprg.elf) ;;
          xbl_feature_config.elf) ;;
          xbl_ramdump.elf) ;;
          xbl_s.melf) ;;
          xbl_s_devprg_ns.melf) ;;
          xbl_sc.elf) ;;
          *)
            echo "Unknown ${file} referenced in ${xml}" >&2
            errors=1
          ;;
        esac
    done
done

if [ "${errors}" != no ]; then
    exit 1
fi
exit 0

