# Verify generated artifacts match the pinned checksums in
# tests/integration/checksums.sha256.

set -eu

manifest="tests/integration/checksums.sha256"

if [ ! -r "${manifest}" ]; then
    echo "Missing manifest: ${manifest}" >&2
    exit 1
fi

sha256sum --quiet --check "${manifest}"
